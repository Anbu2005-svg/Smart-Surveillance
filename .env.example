# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_RELOAD=false
API_LOG_LEVEL=info
AUTH_REQUIRED=true
ENABLE_API_DOCS=false
ALLOWED_USER_EMAILS=
ALLOWED_USER_IDS=

# Model Configuration
MODEL_PATH=best.onnx
DEVICE=cpu
CONFIDENCE_THRESHOLD=0.5
FIRE_CONFIDENCE_THRESHOLD=0.35
WEAPON_CONFIDENCE_THRESHOLD=0.35
USE_HALF_PRECISION=false

# Frame Configuration
FRAME_WIDTH=640
FRAME_HEIGHT=480
MAX_CACHED_FRAMES=40
DETECTION_PROCESS_FPS=12
PROCESS_FRAME_WIDTH=512
PROCESS_FRAME_HEIGHT=384
CAMERA_READ_TIMEOUT_MS=500
JPEG_QUALITY=68
DRAW_MODEL_BOXES=true
DETECTIONS_HISTORY_SIZE=5

# Browser origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Streams and uploads
AUTO_CREATE_DEFAULT_STREAMS=false
STREAMS_STORE_PATH=streams_store.json
VIDEO_UPLOAD_DIR=uploaded_videos
MAX_UPLOAD_SIZE_MB=200
ALLOWED_VIDEO_EXTENSIONS=.mp4,.avi,.mov,.mkv,.webm
LOOP_VIDEO_FILES=true
ALLOWED_CAMERA_URL_SCHEMES=http,https,rtsp,rtmp
BLOCKED_CAMERA_HOSTS=localhost,127.0.0.1,::1,0.0.0.0,169.254.169.254,metadata.google.internal
MAX_WEBCAM_INDEX=16

# Supabase backend auth/storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
# Optional: use a different key for auth verification. Defaults to SUPABASE_ANON_KEY, then SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_AUTH_KEY=
# Required only for backend-owned Supabase table writes/sync.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STREAMS_TABLE=public.camera_streams
SUPABASE_CAMERA_FEEDS_TABLE=public.camera_feeds
SUPABASE_DETECTIONS_TABLE=public.detections
SUPABASE_SECURITY_EVENTS_TABLE=public.security_events
SUPABASE_USER_PROFILES_TABLE=public.user_profiles
SUPABASE_EVENT_LOGGING_ENABLED=true
SUPABASE_DETECTION_LOG_COOLDOWN_SEC=1.0
SUPABASE_TIMEOUT_SEC=10

# Telegram Alerts
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MIN_CONFIDENCE=0.5
TELEGRAM_MIN_CONFIDENCE_FIRE=0.35
TELEGRAM_MIN_CONFIDENCE_WEAPON=0.35
TELEGRAM_COOLDOWN_SEC=5
TELEGRAM_OTP_TTL_SEC=300

# AI Verification
VERIFY_ENABLED=false
VERIFY_PROVIDER=gemini
VERIFY_MODEL=gemini-2.5-pro
VERIFY_API_URL=https://generativelanguage.googleapis.com/v1beta
VERIFY_API_KEYS=
VERIFY_API_KEY=
VERIFY_TIMEOUT_SEC=10
VERIFY_MIN_CONFIDENCE=0.55
VERIFY_SEND_ON_ERROR=false
VERIFY_TARGET_CLASSES=fire,weapon,intruder
ALERT_QUEUE_MAXSIZE=200
VERIFY_ALWAYS_SEND_CLASSES=fire,weapon
ALERT_ENQUEUE_COOLDOWN_SEC=1.0

# Performance
MAX_WORKERS=4
BATCH_SIZE=1
